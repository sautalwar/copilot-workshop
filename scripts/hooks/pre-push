#!/bin/sh
# ============================================================
# pre-push — Run tests before pushing to remote
# ============================================================
# Runs: mvn test -q
# This ensures no broken tests reach the remote repository.
#
# Install: ./scripts/install-hooks.sh
# Skip:    git push --no-verify
# ============================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check if Maven wrapper or mvn is available
if [ -f "./mvnw" ]; then
    MVN="./mvnw"
elif command -v mvn > /dev/null 2>&1; then
    MVN="mvn"
else
    printf "${YELLOW}⚠ Maven not found — skipping pre-push tests.${NC}\n"
    exit 0
fi

printf "${YELLOW}🧪 Running tests before push...${NC}\n"
printf "${YELLOW}   (this may take 10-20 seconds)${NC}\n"

if $MVN test -q -B 2>&1; then
    printf "${GREEN}✓ pre-push: All tests passed. Pushing...${NC}\n"
    exit 0
else
    printf "\n${RED}✗ pre-push: Tests failed! Push blocked.${NC}\n"
    printf "${YELLOW}  Run 'mvn test' to see full output.${NC}\n"
    printf "${YELLOW}  Use 'git push --no-verify' to skip in emergencies.${NC}\n"
    exit 1
fi
